<?xml version="1.0" encoding="UTF-8"?>
<!--
  Production only. Remove this file for development/demo deployments
  where the default user is allowed to be passwordless.

  Replace ${CH_DEFAULT_PASSWORD} with the chosen password before bringing
  the stack up. Prefer password_sha256_hex over plaintext for production:
  echo -n 'your-password' | sha256sum
-->
<clickhouse>
    <users>
        <default>
            <password>${CH_DEFAULT_PASSWORD}</password>
        </default>
    </users>
</clickhouse>
